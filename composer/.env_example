# Docker image tag inputs.
# The compose file pulls ${RSTUDIO_IMAGE_REPO}:${R_VERSION}-${UBUNTU_VERSION}.
RSTUDIO_IMAGE_REPO=dncr/rstudio-server
R_VERSION=latest
UBUNTU_VERSION=noble

# Compose project/container names.
# Change these if you run multiple RStudio containers at the same time.
COMPOSE_PROJECT_NAME=rstudio-latest-noble
CONTAINER_NAME=rstudio-latest-noble

# Host binding.
# 127.0.0.1 keeps RStudio and SSH reachable only from the local machine.
# Use 0.0.0.0 only when you intentionally want to expose them on the network.
BIND_ADDRESS=127.0.0.1
PORT=8002
SSH_PORT=2222

# Runtime user configured by the container startup scripts.
# Keep this aligned with the DEFAULT_USER used when building custom images.
DEFAULT_USER=rstudio
USERID=1000
GROUPID=1000

# Authentication and sudo behavior.
# Change PASSWORD before starting the container. Setting the PASSWORD from 
# terminal environment is recommended.
# Set ROOT=true only when the RStudio user needs passwordless sudo.
# Boolean values accept true/false in any letter case, or 1/0.
PASSWORD=change-me-before-use
ROOT=false
DISABLE_AUTH=false

# Host paths mounted into the container.
# WORKDIR may be relative to this compose directory.
# SSH_PUBLIC_KEY must point to an existing public key file on the host.
WORKDIR=./workspace
SSH_PUBLIC_KEY=/absolute/path/to/id_ed25519.pub

# Container restart behavior.
RESTART_POLICY=unless-stopped
